# WebSocket server port (default 3003; use 8090 if frontend/vite proxy points here)
PORT=8090

# Required: same JWT secret as auth-service (used to verify WebSocket auth tokens).
# If unset, gateway-ws will not start.
JWT_SECRET=dev-jwt-secret-key-change-in-production-minimum-32-characters-long

# NATS URL (optional; common defaults)
# NATS_URL=nats://localhost:4222
