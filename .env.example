# JWT: must match backend/auth-service so gateway-ws validates tokens (WebSocket auth + real-time balance).
# Only needed when using scripts/start-all.sh or running gateway-ws from repo root.
# JWT_SECRET=your-secret-minimum-32-chars

# Optional: Override API base URL.
# - Unset or empty: use Vite proxy (recommended for dev)
# - http://localhost:3000: bypass proxy, call auth-service directly (use if proxy hangs)
# VITE_API_URL=

# Optional: Price stream WebSocket. When set, terminal left panel connects here for live prices.
# - Unset: use same-origin /ws (proxied to gateway-ws on 3003; requires gateway + NATS).
# - ws://localhost:9003: connect directly to data-provider (no gateway needed).
# VITE_DATA_PROVIDER_WS_URL=ws://localhost:9003

# Provider switch (future AWS/Interware integration)
# - false (default): keep current Binance-based implementation
# - true: enable extended AWS/Interware implementation
# VITE_AWS_PROVIDER=false

# Optional: Non-crypto klines provider base URL (used when VITE_AWS_PROVIDER=true).
# Default in code: https://provider.interwarepvt.com
# VITE_INTERWARE_BASE_URL=https://provider.interwarepvt.com

# Optional: Crypto klines provider base URL (reserved for override).
# Default in code: https://api.binance.com
# VITE_BINANCE_REST_URL=https://api.binance.com

# Optional: Exchange rate endpoint (reserved for future frontend usage).
# Default: https://exchange4.dtrader.tech/api/exchange-rate
# VITE_EXCHANGE_RATE_URL=https://exchange4.dtrader.tech/api/exchange-rate
