# JWT: must match backend/auth-service so gateway-ws validates tokens (WebSocket auth + real-time balance).
# Only needed when using scripts/start-all.sh or running gateway-ws from repo root.
# JWT_SECRET=your-secret-minimum-32-chars

# Optional: Override API base URL.
# - Unset or empty: use Vite proxy (recommended for dev)
# - http://localhost:3000: bypass proxy, call auth-service directly (use if proxy hangs)
# VITE_API_URL=

# Optional: Price stream WebSocket. When set, the terminal uses this URL for live ticks even after login
# (otherwise logged-in users would switch to gateway /ws and ticks stop if gateway/NATS is not running).
# - Unset: use same-origin /ws (proxied to gateway-ws; requires gateway + NATS for live updates).
# - ws://localhost:9003: data-provider directly (no gateway).
# VITE_DATA_PROVIDER_WS_URL=ws://localhost:9003

# Optional: data-provider HTTP base for snapshots and MMDPS chart history proxy (`GET /feed/history`).
# If unset, derived from VITE_DATA_PROVIDER_WS_URL (e.g. ws port 9003 → http port 9004).
# VITE_DATA_PROVIDER_HTTP_URL=http://localhost:9004

# Optional: comma list forces MMDPS chart history only for those symbols. Unset + VITE_DATA_PROVIDER_*: auto (non–Binance-style → MMDPS for all). Empty string = Binance-only charts.
# VITE_MMDPS_SYMBOLS=

# Data-provider: MMDPS_API_KEY=…
# Same key is used by scripts/prune-symbols-keep-crypto-and-mmdps-feed.sh unless you set MMDPS_SYMBOLS_URL with api_key=…
# MMDPS_AUTO_ROUTE=true   # default: *USDT/*USDC/… → Binance; forex/equities → MMDPS
# MMDPS_SYMBOLS=          # optional bootstrap seeds; leave empty with auto-routing
#
# Data-provider: optional Postgres catalog (same DATABASE_URL as auth-service) so upstream MMDPS
# subscribes to all enabled forex/commodities/indices/stocks from the `symbols` table — no manual list.
# SYMBOLS_DATABASE_URL=postgres://…   # overrides DATABASE_URL if both set
# SYMBOLS_CATALOG_REFRESH_SECS=300    # periodic merge (0 = startup only)
# CATALOG_MMDPS_MAX_SYMBOLS=25000
