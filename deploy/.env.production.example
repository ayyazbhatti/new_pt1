# Copy to deploy/.env.production and set values. Used by docker-compose.prod.yml
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-minimum-32-characters-long-secret
JWT_ISSUER=newpt

# Voiso Click2Call (Admin → Voiso). Get key from Voiso dashboard.
VOISO_API_KEY=

# --- MMDPS (forex/CFD live feed, chart history, admin “Sync from MMDPS”) ---
# Required for data-provider MMDPS WebSocket + `/feed/history` proxy and auth-service sync.
# Get your key from the MMDPS operator dashboard (same value you use in local dev).
MMDPS_API_KEY=
# Optional: override endpoints (defaults: wss://api.mmdps.uk/feed/ws, https://api.mmdps.uk/feed/history)
# MMDPS_WS_BASE=
# MMDPS_HISTORY_BASE=
# Optional: explicit symbol list when MMDPS_AUTO_ROUTE=false (comma-separated)
# MMDPS_SYMBOLS=
# MMDPS_AUTO_ROUTE defaults to true when MMDPS_API_KEY is set

# Feed freshness / watchdog (data-provider):
# If upstream ticks become stale for N consecutive checks, data-provider forces reconnect/resubscribe.
# FEED_FRESHNESS_BINANCE_MAX_STALE_SECS=120
# FEED_FRESHNESS_MMDPS_MAX_STALE_SECS=180
# FEED_WATCHDOG_INTERVAL_SECS=20
# FEED_WATCHDOG_STALE_THRESHOLD=3
