# WebSocket server (default in code: 3003 — matches Vite + frontend dev URL)
WS_PORT=3003
HTTP_PORT=9002

# Required: must match auth-service JWT_SECRET exactly so tokens validate and group_id is correct
JWT_SECRET=your-jwt-secret-minimum-32-chars
JWT_ISSUER=newpt

# Redis (same as data-provider / auth-service)
REDIS_URL=redis://127.0.0.1:6379
