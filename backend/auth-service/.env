# Local dev — aligns with repo root .env for JWT and DB.
# Docker: use container `newpt-postgres` on host port 5433 (not swapx-postgres on the same port).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/newpt
JWT_SECRET=dev-jwt-secret-key-change-in-production-minimum-32-characters-long
JWT_ISSUER=newpt
