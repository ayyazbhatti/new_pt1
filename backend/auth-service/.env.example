# Copy to .env for local dev. Must match core-api / repo root DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/newpt

# Admin → System: JSON written by deploy/scripts/collect-system-stats*.sh (default in Docker: /host-stats/system-stats.json).
# Local macOS/Linux: run `./deploy/scripts/collect-system-stats-local.sh` then point here (absolute path recommended):
# SYSTEM_STATS_FILE=/Users/you/new_pt1/deploy/stats/system-stats.json
# Or use a static placeholder: SYSTEM_STATS_FILE=/Users/you/new_pt1/backend/auth-service/dev-data/system-stats.example.json
